# Database
DATABASE_URL=postgresql://chargeplus:chargeplus@db:5432/chargeplus

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Django
SECRET_KEY=change-me-in-production-use-long-random-string
DJANGO_SETTINGS_MODULE=chargeplus.settings.development
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Gateway
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=9000
OCPP_SECURITY_PROFILE=0

# JWT
JWT_ACCESS_TOKEN_LIFETIME_HOURS=24

# Notifications (optional)
KAKAO_API_KEY=
SMS_API_KEY=

# Sentry (optional)
SENTRY_DSN=
